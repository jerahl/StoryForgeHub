# /etc/codex/codex.env — runtime secrets for Stephen's Codex (Debian VPS).
#
# Read by config.php via getenv() (php-fpm pool injects these), and by the
# codex-mcp service. Root-owned, mode 640, group www-data. NEVER commit a real
# copy of this file. 03-setup-app.sh generates DB_PASSWORD and API_KEY for you;
# the placeholders below are only used if you fill it in by hand.
#
# After the migration off Wasmer, ROTATE every value that was ever committed in
# plaintext: API_KEY, DB_PASSWORD, APP_PASSWORD.

# --- MySQL / MariaDB (local socket, no egress) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=codex
DB_USERNAME=codex
DB_PASSWORD=CHANGE_ME

# --- REST API token (X-Codex-Token header; used by the MCP service) ---
API_KEY=CHANGE_ME

# --- Optional single-password UI login. Empty string disables the gate. ---
APP_PASSWORD=

# --- Canonical books root (enables in-app chapter editing — Phase 9). ---
# Empty leaves chapters read-only. php-fpm must have write access to this tree.
CODEX_BOOKS_DIR=/srv/codex/books
