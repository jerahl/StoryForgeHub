# deploy.env — active settings for the Codex VPS setup scripts.
# Sourced by lib.sh; overrides the defaults. Not deployed to the server.

# Public hostname — DNS A record for this must point at the VPS public IP.
CODEX_DOMAIN=storyforgehub.cloud

# Non-root sudo user (created by 01-provision.sh if missing).
CODEX_ADMIN_USER=codex

# Filesystem layout (docroot = $CODEX_APP_ROOT/htdocs).
CODEX_APP_ROOT=/srv/codex/app
CODEX_BOOKS_DIR=/srv/codex/books
CODEX_ENV_FILE=/etc/codex/codex.env

# Database.
CODEX_DB_NAME=codex
CODEX_DB_USER=codex

# PHP.
PHP_VERSION=8.3

# Web server: caddy (auto-HTTPS, recommended) or nginx (uses certbot).
WEB_SERVER=caddy

# Continuous sync cadence (minutes) for codex-sync.timer.
SYNC_INTERVAL_MIN=5

# Backups.
BACKUP_DIR=/var/backups/codex
