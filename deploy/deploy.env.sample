# deploy.env — settings for the Codex VPS setup scripts.
# Copy to deploy/deploy.env and edit, OR export these in your shell before
# running setup.sh. Anything you leave unset uses the defaults shown here.

# Public hostname — point a DNS A record at this box first.
CODEX_DOMAIN=codex.example.com

# Non-root sudo user (created by 01-provision.sh if missing).
CODEX_ADMIN_USER=codex

# Filesystem layout.
CODEX_APP_ROOT=/srv/codex/app
CODEX_BOOKS_DIR=/srv/codex/books
CODEX_ENV_FILE=/etc/codex/codex.env

# Database.
CODEX_DB_NAME=codex
CODEX_DB_USER=codex

# PHP.
PHP_VERSION=8.3

# Web server: caddy (auto-HTTPS, recommended) or nginx (uses certbot).
WEB_SERVER=caddy

# Continuous sync cadence (minutes) for codex-sync.timer.
SYNC_INTERVAL_MIN=5

# Backups.
BACKUP_DIR=/var/backups/codex
